{
  "ReverseProxy": {
    "Routes": {

      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/catalog/{**catch-all}"
        }
      },

      "ordering-route": {
        "ClusterId": "ordering-cluster",
        "Match": {
          "Path": "/ordering/{**catch-all}"
        }
      }

    },

    "Clusters": {

      "catalog-cluster": {
        "Destinations": {
          "catalog-api": {
            "Address": "http://catalog-api:8080/"
          }
        }
      },

      "ordering-cluster": {
        "Destinations": {
          "ordering-api": {
            "Address": "http://ordering-api:8080/"
          }
        }
      }

    }
  }
}
